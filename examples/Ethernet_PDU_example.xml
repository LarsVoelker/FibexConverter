<?xml version="1.0" encoding="UTF-8"?>
<!--
    Ethernet PDU FIBEX 4.1.2 Example

    A simple Ethernet network carrying application frames with PDUs and signals,
    mirroring the CAN_example structure but over an Ethernet VLAN.

    Network:
      - Cluster: ETH1 (Gigabit Ethernet, VLAN 100, 10.0.0.0/24)
      - Channel: VLAN100_CH (ethernet:CHANNEL-TYPE)

    Frames:
      - EngineStatus  (8 bytes)
          EngineSpeed   bits  0-15  uint16  little-endian
          CoolantTemp   bits 16-23  uint8
          EngineLoad    bits 24-31  uint8

      - BrakeStatus   (2 bytes)
          BrakePressure bits  0-15  uint16  little-endian

    ECUs:
      - ECU_Engine    (10.0.0.1 UDP:50000)  transmits EngineStatus
      - ECU_Brake     (10.0.0.2 UDP:50001)  transmits BrakeStatus
      - ECU_Dashboard (10.0.0.3 UDP:50002)  receives both frames
-->
<fx:FIBEX xmlns:fx="http://www.asam.net/xml/fbx"
          xmlns:ho="http://www.asam.net/xml"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:ethernet="http://www.asam.net/xml/fbx/ethernet"
          xmlns:it="http://www.asam.net/xml/fbx/it"
          VERSION="4.1.2">

  <fx:PROJECT ID="ETH_PDU_Example_Project">
    <ho:SHORT-NAME>Ethernet_PDU_Example</ho:SHORT-NAME>
  </fx:PROJECT>

  <fx:ELEMENTS>

    <!-- ============================================================ -->
    <!-- CHANNELS                                                       -->
    <!-- ============================================================ -->
    <fx:CHANNELS>
      <fx:CHANNEL ID="VLAN100_CH" xsi:type="ethernet:CHANNEL-TYPE">
        <ho:SHORT-NAME>VLAN100_CH</ho:SHORT-NAME>
        <ho:DESC>Ethernet VLAN 100 carrying application frames</ho:DESC>
        <fx:FRAME-TRIGGERINGS>

          <!-- EngineStatus frame triggering (no CAN ID on Ethernet) -->
          <fx:FRAME-TRIGGERING ID="FT_EngineStatus">
            <fx:FRAME-REF ID-REF="FR_EngineStatus"/>
          </fx:FRAME-TRIGGERING>

          <!-- BrakeStatus frame triggering -->
          <fx:FRAME-TRIGGERING ID="FT_BrakeStatus">
            <fx:FRAME-REF ID-REF="FR_BrakeStatus"/>
          </fx:FRAME-TRIGGERING>

        </fx:FRAME-TRIGGERINGS>
        <ethernet:VIRTUAL-LAN ID="VLAN100">
          <ho:SHORT-NAME>VLAN100</ho:SHORT-NAME>
          <ethernet:VLAN-IDENTIFIER>100</ethernet:VLAN-IDENTIFIER>
        </ethernet:VIRTUAL-LAN>
      </fx:CHANNEL>
    </fx:CHANNELS>

    <!-- ============================================================ -->
    <!-- ECUS                                                           -->
    <!-- ============================================================ -->
    <fx:ECUS>

      <!-- ECU_Engine: transmits EngineStatus -->
      <fx:ECU ID="ECU_Engine">
        <ho:SHORT-NAME>ECU_Engine</ho:SHORT-NAME>
        <ho:DESC>Engine control unit — transmits EngineStatus over Ethernet</ho:DESC>
        <fx:CONTROLLERS>
          <fx:CONTROLLER ID="ECU_Engine_Ctrl">
            <ho:SHORT-NAME>ECU_Engine_Ctrl</ho:SHORT-NAME>
          </fx:CONTROLLER>
        </fx:CONTROLLERS>
        <fx:CONNECTORS>
          <fx:CONNECTOR ID="ECU_Engine_Conn" xsi:type="it:CONNECTOR-TYPE">
            <fx:CHANNEL-REF ID-REF="VLAN100_CH"/>
            <fx:CONTROLLER-REF ID-REF="ECU_Engine_Ctrl"/>
            <fx:OUTPUTS>
              <fx:OUTPUT-PORT ID="ECU_Engine_Out_EngineStatus">
                <fx:FRAME-TRIGGERING-REF ID-REF="FT_EngineStatus"/>
                <fx:COMPLETE-FRAME/>
              </fx:OUTPUT-PORT>
            </fx:OUTPUTS>
            <it:NETWORK-ENDPOINTS>
              <it:NETWORK-ENDPOINT ID="NEP_Engine">
                <ho:SHORT-NAME>Engine_NEP</ho:SHORT-NAME>
                <it:NETWORK-ENDPOINT-ADDRESSES>
                  <it:NETWORK-ENDPOINT-ADDRESS>
                    <it:IPV4>
                      <it:IP-ADDRESS>10.0.0.1</it:IP-ADDRESS>
                      <it:IPV4-ADDRESS-SOURCE>FIXED</it:IPV4-ADDRESS-SOURCE>
                      <it:NETWORKMASK>255.255.255.0</it:NETWORKMASK>
                    </it:IPV4>
                  </it:NETWORK-ENDPOINT-ADDRESS>
                </it:NETWORK-ENDPOINT-ADDRESSES>
              </it:NETWORK-ENDPOINT>
            </it:NETWORK-ENDPOINTS>
            <it:APPLICATION-ENDPOINTS>
              <it:APPLICATION-ENDPOINT ID="AEP_Engine">
                <ho:SHORT-NAME>Engine_AEP</ho:SHORT-NAME>
                <it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                  <it:UDP-TP>
                    <it:UDP-PORT>
                      <it:PORT-NUMBER>50000</it:PORT-NUMBER>
                    </it:UDP-PORT>
                  </it:UDP-TP>
                </it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                <it:NETWORK-ENDPOINT-REF ID-REF="NEP_Engine"/>
              </it:APPLICATION-ENDPOINT>
            </it:APPLICATION-ENDPOINTS>
          </fx:CONNECTOR>
        </fx:CONNECTORS>
      </fx:ECU>

      <!-- ECU_Brake: transmits BrakeStatus -->
      <fx:ECU ID="ECU_Brake">
        <ho:SHORT-NAME>ECU_Brake</ho:SHORT-NAME>
        <ho:DESC>Brake control unit — transmits BrakeStatus over Ethernet</ho:DESC>
        <fx:CONTROLLERS>
          <fx:CONTROLLER ID="ECU_Brake_Ctrl">
            <ho:SHORT-NAME>ECU_Brake_Ctrl</ho:SHORT-NAME>
          </fx:CONTROLLER>
        </fx:CONTROLLERS>
        <fx:CONNECTORS>
          <fx:CONNECTOR ID="ECU_Brake_Conn" xsi:type="it:CONNECTOR-TYPE">
            <fx:CHANNEL-REF ID-REF="VLAN100_CH"/>
            <fx:CONTROLLER-REF ID-REF="ECU_Brake_Ctrl"/>
            <fx:OUTPUTS>
              <fx:OUTPUT-PORT ID="ECU_Brake_Out_BrakeStatus">
                <fx:FRAME-TRIGGERING-REF ID-REF="FT_BrakeStatus"/>
                <fx:COMPLETE-FRAME/>
              </fx:OUTPUT-PORT>
            </fx:OUTPUTS>
            <it:NETWORK-ENDPOINTS>
              <it:NETWORK-ENDPOINT ID="NEP_Brake">
                <ho:SHORT-NAME>Brake_NEP</ho:SHORT-NAME>
                <it:NETWORK-ENDPOINT-ADDRESSES>
                  <it:NETWORK-ENDPOINT-ADDRESS>
                    <it:IPV4>
                      <it:IP-ADDRESS>10.0.0.2</it:IP-ADDRESS>
                      <it:IPV4-ADDRESS-SOURCE>FIXED</it:IPV4-ADDRESS-SOURCE>
                      <it:NETWORKMASK>255.255.255.0</it:NETWORKMASK>
                    </it:IPV4>
                  </it:NETWORK-ENDPOINT-ADDRESS>
                </it:NETWORK-ENDPOINT-ADDRESSES>
              </it:NETWORK-ENDPOINT>
            </it:NETWORK-ENDPOINTS>
            <it:APPLICATION-ENDPOINTS>
              <it:APPLICATION-ENDPOINT ID="AEP_Brake">
                <ho:SHORT-NAME>Brake_AEP</ho:SHORT-NAME>
                <it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                  <it:UDP-TP>
                    <it:UDP-PORT>
                      <it:PORT-NUMBER>50001</it:PORT-NUMBER>
                    </it:UDP-PORT>
                  </it:UDP-TP>
                </it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                <it:NETWORK-ENDPOINT-REF ID-REF="NEP_Brake"/>
              </it:APPLICATION-ENDPOINT>
            </it:APPLICATION-ENDPOINTS>
          </fx:CONNECTOR>
        </fx:CONNECTORS>
      </fx:ECU>

      <!-- ECU_Dashboard: receives both frames -->
      <fx:ECU ID="ECU_Dashboard">
        <ho:SHORT-NAME>ECU_Dashboard</ho:SHORT-NAME>
        <ho:DESC>Dashboard unit — receives EngineStatus and BrakeStatus over Ethernet</ho:DESC>
        <fx:CONTROLLERS>
          <fx:CONTROLLER ID="ECU_Dashboard_Ctrl">
            <ho:SHORT-NAME>ECU_Dashboard_Ctrl</ho:SHORT-NAME>
          </fx:CONTROLLER>
        </fx:CONTROLLERS>
        <fx:CONNECTORS>
          <fx:CONNECTOR ID="ECU_Dashboard_Conn" xsi:type="it:CONNECTOR-TYPE">
            <fx:CHANNEL-REF ID-REF="VLAN100_CH"/>
            <fx:CONTROLLER-REF ID-REF="ECU_Dashboard_Ctrl"/>
            <fx:INPUTS>
              <fx:INPUT-PORT ID="ECU_Dashboard_In_EngineStatus">
                <fx:FRAME-TRIGGERING-REF ID-REF="FT_EngineStatus"/>
                <fx:COMPLETE-FRAME/>
              </fx:INPUT-PORT>
              <fx:INPUT-PORT ID="ECU_Dashboard_In_BrakeStatus">
                <fx:FRAME-TRIGGERING-REF ID-REF="FT_BrakeStatus"/>
                <fx:COMPLETE-FRAME/>
              </fx:INPUT-PORT>
            </fx:INPUTS>
            <it:NETWORK-ENDPOINTS>
              <it:NETWORK-ENDPOINT ID="NEP_Dashboard">
                <ho:SHORT-NAME>Dashboard_NEP</ho:SHORT-NAME>
                <it:NETWORK-ENDPOINT-ADDRESSES>
                  <it:NETWORK-ENDPOINT-ADDRESS>
                    <it:IPV4>
                      <it:IP-ADDRESS>10.0.0.3</it:IP-ADDRESS>
                      <it:IPV4-ADDRESS-SOURCE>FIXED</it:IPV4-ADDRESS-SOURCE>
                      <it:NETWORKMASK>255.255.255.0</it:NETWORKMASK>
                    </it:IPV4>
                  </it:NETWORK-ENDPOINT-ADDRESS>
                </it:NETWORK-ENDPOINT-ADDRESSES>
              </it:NETWORK-ENDPOINT>
            </it:NETWORK-ENDPOINTS>
            <it:APPLICATION-ENDPOINTS>
              <it:APPLICATION-ENDPOINT ID="AEP_Dashboard">
                <ho:SHORT-NAME>Dashboard_AEP</ho:SHORT-NAME>
                <it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                  <it:UDP-TP>
                    <it:UDP-PORT>
                      <it:PORT-NUMBER>50002</it:PORT-NUMBER>
                    </it:UDP-PORT>
                  </it:UDP-TP>
                </it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                <it:NETWORK-ENDPOINT-REF ID-REF="NEP_Dashboard"/>
              </it:APPLICATION-ENDPOINT>
            </it:APPLICATION-ENDPOINTS>
          </fx:CONNECTOR>
        </fx:CONNECTORS>
      </fx:ECU>

    </fx:ECUS>

    <!-- ============================================================ -->
    <!-- PDUS — signal containers embedded in frames                   -->
    <!-- ============================================================ -->
    <fx:PDUS>

      <!-- PDU carrying EngineStatus signals (8 bytes) -->
      <fx:PDU ID="PDU_EngineStatus">
        <ho:SHORT-NAME>PDU_EngineStatus</ho:SHORT-NAME>
        <fx:BYTE-LENGTH>8</fx:BYTE-LENGTH>
        <fx:PDU-TYPE>APPLICATION</fx:PDU-TYPE>
        <fx:SIGNAL-INSTANCES>

          <!-- EngineSpeed: bits 0-15, little-endian uint16 -->
          <fx:SIGNAL-INSTANCE ID="SI_EngineSpeed">
            <fx:BIT-POSITION>0</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
            <fx:SIGNAL-REF ID-REF="SIG_EngineSpeed"/>
          </fx:SIGNAL-INSTANCE>

          <!-- CoolantTemp: bits 16-23, uint8 -->
          <fx:SIGNAL-INSTANCE ID="SI_CoolantTemp">
            <fx:BIT-POSITION>16</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
            <fx:SIGNAL-REF ID-REF="SIG_CoolantTemp"/>
          </fx:SIGNAL-INSTANCE>

          <!-- EngineLoad: bits 24-31, uint8 -->
          <fx:SIGNAL-INSTANCE ID="SI_EngineLoad">
            <fx:BIT-POSITION>24</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
            <fx:SIGNAL-REF ID-REF="SIG_EngineLoad"/>
          </fx:SIGNAL-INSTANCE>

        </fx:SIGNAL-INSTANCES>
      </fx:PDU>

      <!-- PDU carrying BrakeStatus signals (2 bytes) -->
      <fx:PDU ID="PDU_BrakeStatus">
        <ho:SHORT-NAME>PDU_BrakeStatus</ho:SHORT-NAME>
        <fx:BYTE-LENGTH>2</fx:BYTE-LENGTH>
        <fx:PDU-TYPE>APPLICATION</fx:PDU-TYPE>
        <fx:SIGNAL-INSTANCES>

          <!-- BrakePressure: bits 0-15, little-endian uint16 -->
          <fx:SIGNAL-INSTANCE ID="SI_BrakePressure">
            <fx:BIT-POSITION>0</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
            <fx:SIGNAL-REF ID-REF="SIG_BrakePressure"/>
          </fx:SIGNAL-INSTANCE>

        </fx:SIGNAL-INSTANCES>
      </fx:PDU>

    </fx:PDUS>

    <!-- ============================================================ -->
    <!-- FRAMES                                                         -->
    <!-- ============================================================ -->
    <fx:FRAMES>

      <!-- EngineStatus: 8-byte frame containing one PDU -->
      <fx:FRAME ID="FR_EngineStatus">
        <ho:SHORT-NAME>EngineStatus</ho:SHORT-NAME>
        <ho:DESC>Engine status frame transmitted by ECU_Engine</ho:DESC>
        <fx:BYTE-LENGTH>8</fx:BYTE-LENGTH>
        <fx:PDU-INSTANCES>
          <fx:PDU-INSTANCE ID="PDU_INST_EngineStatus">
            <fx:PDU-REF ID-REF="PDU_EngineStatus"/>
            <fx:BIT-POSITION>0</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
          </fx:PDU-INSTANCE>
        </fx:PDU-INSTANCES>
      </fx:FRAME>

      <!-- BrakeStatus: 2-byte frame containing one PDU -->
      <fx:FRAME ID="FR_BrakeStatus">
        <ho:SHORT-NAME>BrakeStatus</ho:SHORT-NAME>
        <ho:DESC>Brake status frame transmitted by ECU_Brake</ho:DESC>
        <fx:BYTE-LENGTH>2</fx:BYTE-LENGTH>
        <fx:PDU-INSTANCES>
          <fx:PDU-INSTANCE ID="PDU_INST_BrakeStatus">
            <fx:PDU-REF ID-REF="PDU_BrakeStatus"/>
            <fx:BIT-POSITION>0</fx:BIT-POSITION>
            <fx:IS-HIGH-LOW-BYTE-ORDER>false</fx:IS-HIGH-LOW-BYTE-ORDER>
          </fx:PDU-INSTANCE>
        </fx:PDU-INSTANCES>
      </fx:FRAME>

    </fx:FRAMES>

    <!-- ============================================================ -->
    <!-- SIGNALS                                                        -->
    <!-- ============================================================ -->
    <fx:SIGNALS>

      <fx:SIGNAL ID="SIG_EngineSpeed">
        <ho:SHORT-NAME>EngineSpeed</ho:SHORT-NAME>
        <ho:DESC>Engine speed in rpm</ho:DESC>
        <fx:CODING-REF ID-REF="COD_UINT16_12"/>
      </fx:SIGNAL>

      <fx:SIGNAL ID="SIG_CoolantTemp">
        <ho:SHORT-NAME>CoolantTemp</ho:SHORT-NAME>
        <ho:DESC>Coolant temperature in deg C (offset -40)</ho:DESC>
        <fx:CODING-REF ID-REF="COD_UINT8_4"/>
      </fx:SIGNAL>

      <fx:SIGNAL ID="SIG_EngineLoad">
        <ho:SHORT-NAME>EngineLoad</ho:SHORT-NAME>
        <ho:DESC>Engine load in percent</ho:DESC>
        <fx:CODING-REF ID-REF="COD_UINT8_4"/>
      </fx:SIGNAL>

      <fx:SIGNAL ID="SIG_BrakePressure">
        <ho:SHORT-NAME>BrakePressure</ho:SHORT-NAME>
        <ho:DESC>Brake pressure in kPa</ho:DESC>
        <fx:CODING-REF ID-REF="COD_UINT16_12"/>
      </fx:SIGNAL>

    </fx:SIGNALS>

  </fx:ELEMENTS>

  <!-- ============================================================== -->
  <!-- PROCESSING-INFORMATION: signal codings                          -->
  <!-- ============================================================== -->
  <fx:PROCESSING-INFORMATION>
    <fx:CODINGS>

      <!-- 12-bit unsigned integer with linear scaling: physical = 0.5 * raw -->
      <fx:CODING ID="COD_UINT16_12">
        <ho:SHORT-NAME>UINT16</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_UINT16" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>12</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
        <ho:COMPU-METHODS>
          <ho:COMPU-METHOD>
            <ho:SHORT-NAME>Linear_0_5</ho:SHORT-NAME>
            <ho:CATEGORY>LINEAR</ho:CATEGORY>
            <ho:COMPU-INTERNAL-TO-PHYS>
              <ho:COMPU-SCALES>
                <ho:COMPU-SCALE>
                  <ho:COMPU-RATIONAL-COEFFS>
                    <ho:COMPU-NUMERATOR>
                      <ho:V>0.0</ho:V>
                      <ho:V>0.5</ho:V>
                    </ho:COMPU-NUMERATOR>
                    <ho:COMPU-DENOMINATOR>
                      <ho:V>1.0</ho:V>
                    </ho:COMPU-DENOMINATOR>
                  </ho:COMPU-RATIONAL-COEFFS>
                </ho:COMPU-SCALE>
              </ho:COMPU-SCALES>
            </ho:COMPU-INTERNAL-TO-PHYS>
          </ho:COMPU-METHOD>
        </ho:COMPU-METHODS>
      </fx:CODING>

      <!-- 4-bit unsigned integer with named constants (no linear scaling) -->
      <fx:CODING ID="COD_UINT8_4">
        <ho:SHORT-NAME>UINT8</ho:SHORT-NAME>
        <ho:CODED-TYPE ho:BASE-DATA-TYPE="A_UINT8" CATEGORY="STANDARD-LENGTH-TYPE">
          <ho:BIT-LENGTH>4</ho:BIT-LENGTH>
        </ho:CODED-TYPE>
        <ho:COMPU-METHODS>
          <ho:COMPU-METHOD>
            <ho:SHORT-NAME>UINT8_Consts</ho:SHORT-NAME>
            <ho:CATEGORY>TEXTTABLE</ho:CATEGORY>
            <ho:COMPU-INTERNAL-TO-PHYS>
              <ho:COMPU-SCALES>
                <ho:COMPU-SCALE>
                  <ho:LOWER-LIMIT>0</ho:LOWER-LIMIT>
                  <ho:UPPER-LIMIT>0</ho:UPPER-LIMIT>
                  <ho:COMPU-CONST>
                    <ho:VT>ERROR</ho:VT>
                  </ho:COMPU-CONST>
                </ho:COMPU-SCALE>
                <ho:COMPU-SCALE>
                  <ho:LOWER-LIMIT>1</ho:LOWER-LIMIT>
                  <ho:UPPER-LIMIT>1</ho:UPPER-LIMIT>
                  <ho:COMPU-CONST>
                    <ho:VT>NOT_AVAILABLE</ho:VT>
                  </ho:COMPU-CONST>
                </ho:COMPU-SCALE>
              </ho:COMPU-SCALES>
            </ho:COMPU-INTERNAL-TO-PHYS>
          </ho:COMPU-METHOD>
        </ho:COMPU-METHODS>
      </fx:CODING>

    </fx:CODINGS>
  </fx:PROCESSING-INFORMATION>

</fx:FIBEX>
