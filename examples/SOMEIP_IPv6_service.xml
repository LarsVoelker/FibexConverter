<?xml version="1.0" encoding="UTF-8"?>
<!--
    Scenario: Single SOME/IP service over IPv6 with provider and consumer.

    Service:  SVC_ECHO6  (ID=0x1235, version 1.0)
      Method: GetValue  (method_id=1,  REQUEST_RESPONSE, uint8 in/out)
      Event:  StatusEvent (method_id=0x8001, uint8 payload)
      Eventgroup: EG1   (eventgroup_id=1, contains StatusEvent)

    Topology:
      ECU_PROVIDER6 (2001:db8::1/64) provides SVC_ECHO6 (instance 1) on UDP:30000
      ECU_CONSUMER6 (2001:db8::2/64) consumes SVC_ECHO6 (instance 1) on UDP:30001
-->
<fx:FIBEX xmlns:fx="http://www.asam.net/xml/fbx"
          xmlns:ho="http://www.asam.net/xml"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns:ethernet="http://www.asam.net/xml/fbx/ethernet"
          xmlns:service="http://www.asam.net/xml/fbx/services"
          xmlns:it="http://www.asam.net/xml/fbx/it"
          VERSION="4.1.2">

    <fx:PROJECT ID="PROJ_SOMEIP6">
        <ho:SHORT-NAME>SomeIPIPv6ServiceTest</ho:SHORT-NAME>
    </fx:PROJECT>

    <fx:ELEMENTS>

        <fx:CHANNELS>
            <fx:CHANNEL ID="CHAN6_VLAN100" xsi:type="ethernet:CHANNEL-TYPE">
                <ho:SHORT-NAME>VLAN100_IPv6</ho:SHORT-NAME>
                <ethernet:VIRTUAL-LAN ID="VLAN100_IPv6">
                    <ho:SHORT-NAME>VLAN100_IPv6</ho:SHORT-NAME>
                    <ethernet:VLAN-IDENTIFIER>100</ethernet:VLAN-IDENTIFIER>
                </ethernet:VIRTUAL-LAN>
            </fx:CHANNEL>
        </fx:CHANNELS>

        <fx:ECUS>

            <fx:ECU ID="ECU_PROVIDER6">
                <ho:SHORT-NAME>ECU_PROVIDER6</ho:SHORT-NAME>
                <fx:CONTROLLERS>
                    <fx:CONTROLLER ID="CTRL_PROVIDER6">
                        <ho:SHORT-NAME>Provider6_Ctrl</ho:SHORT-NAME>
                    </fx:CONTROLLER>
                </fx:CONTROLLERS>
                <fx:CONNECTORS>
                    <fx:CONNECTOR ID="CONN_PROVIDER6" xsi:type="it:CONNECTOR-TYPE">
                        <fx:CHANNEL-REF ID-REF="CHAN6_VLAN100"/>
                        <fx:CONTROLLER-REF ID-REF="CTRL_PROVIDER6"/>

                        <it:NETWORK-ENDPOINTS>
                            <it:NETWORK-ENDPOINT ID="NEP_PROVIDER6">
                                <ho:SHORT-NAME>Provider6_NEP</ho:SHORT-NAME>
                                <it:NETWORK-ENDPOINT-ADDRESSES>
                                    <it:NETWORK-ENDPOINT-ADDRESS>
                                        <it:IPV6>
                                            <it:IPV6-ADDRESS>2001:db8::1</it:IPV6-ADDRESS>
                                            <it:IP-ADDRESS-PREFIX-LENGTH>64</it:IP-ADDRESS-PREFIX-LENGTH>
                                            <it:IPV6-ADDRESS-SOURCE>FIXED</it:IPV6-ADDRESS-SOURCE>
                                        </it:IPV6>
                                    </it:NETWORK-ENDPOINT-ADDRESS>
                                </it:NETWORK-ENDPOINT-ADDRESSES>
                            </it:NETWORK-ENDPOINT>
                        </it:NETWORK-ENDPOINTS>

                        <it:APPLICATION-ENDPOINTS>
                            <it:APPLICATION-ENDPOINT ID="AEP_PROVIDER6">
                                <ho:SHORT-NAME>Provider6_AEP</ho:SHORT-NAME>
                                <it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                                    <it:UDP-TP>
                                        <it:UDP-PORT>
                                            <it:PORT-NUMBER>30000</it:PORT-NUMBER>
                                        </it:UDP-PORT>
                                    </it:UDP-TP>
                                </it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                                <it:NETWORK-ENDPOINT-REF ID-REF="NEP_PROVIDER6"/>
                                <it:PROVIDED-SERVICE-INSTANCES>
                                    <it:PROVIDED-SERVICE-INSTANCE ID="PSI_ECHO6">
                                        <it:INSTANCE-IDENTIFIER>1</it:INSTANCE-IDENTIFIER>
                                        <service:SERVICE-INTERFACE-REF ID-REF="SVC_ECHO6"/>
                                        <it:EVENT-HANDLERS>
                                            <it:EVENT-HANDLER>
                                                <it:CONSUMED-EVENT-GROUP-REFS>
                                                    <it:CONSUMED-EVENT-GROUP-REF ID-REF="CEG6_EG1"/>
                                                </it:CONSUMED-EVENT-GROUP-REFS>
                                                <it:APPLICATION-ENDPOINT-REF ID-REF="AEP_PROVIDER6"/>
                                            </it:EVENT-HANDLER>
                                        </it:EVENT-HANDLERS>
                                    </it:PROVIDED-SERVICE-INSTANCE>
                                </it:PROVIDED-SERVICE-INSTANCES>
                            </it:APPLICATION-ENDPOINT>
                        </it:APPLICATION-ENDPOINTS>

                    </fx:CONNECTOR>
                </fx:CONNECTORS>
            </fx:ECU>

            <fx:ECU ID="ECU_CONSUMER6">
                <ho:SHORT-NAME>ECU_CONSUMER6</ho:SHORT-NAME>
                <fx:CONTROLLERS>
                    <fx:CONTROLLER ID="CTRL_CONSUMER6">
                        <ho:SHORT-NAME>Consumer6_Ctrl</ho:SHORT-NAME>
                    </fx:CONTROLLER>
                </fx:CONTROLLERS>
                <fx:CONNECTORS>
                    <fx:CONNECTOR ID="CONN_CONSUMER6" xsi:type="it:CONNECTOR-TYPE">
                        <fx:CHANNEL-REF ID-REF="CHAN6_VLAN100"/>
                        <fx:CONTROLLER-REF ID-REF="CTRL_CONSUMER6"/>

                        <it:NETWORK-ENDPOINTS>
                            <it:NETWORK-ENDPOINT ID="NEP_CONSUMER6">
                                <ho:SHORT-NAME>Consumer6_NEP</ho:SHORT-NAME>
                                <it:NETWORK-ENDPOINT-ADDRESSES>
                                    <it:NETWORK-ENDPOINT-ADDRESS>
                                        <it:IPV6>
                                            <it:IPV6-ADDRESS>2001:db8::2</it:IPV6-ADDRESS>
                                            <it:IP-ADDRESS-PREFIX-LENGTH>64</it:IP-ADDRESS-PREFIX-LENGTH>
                                            <it:IPV6-ADDRESS-SOURCE>FIXED</it:IPV6-ADDRESS-SOURCE>
                                        </it:IPV6>
                                    </it:NETWORK-ENDPOINT-ADDRESS>
                                </it:NETWORK-ENDPOINT-ADDRESSES>
                            </it:NETWORK-ENDPOINT>
                        </it:NETWORK-ENDPOINTS>

                        <it:APPLICATION-ENDPOINTS>
                            <it:APPLICATION-ENDPOINT ID="AEP_CONSUMER6">
                                <ho:SHORT-NAME>Consumer6_AEP</ho:SHORT-NAME>
                                <it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                                    <it:UDP-TP>
                                        <it:UDP-PORT>
                                            <it:PORT-NUMBER>30001</it:PORT-NUMBER>
                                        </it:UDP-PORT>
                                    </it:UDP-TP>
                                </it:IT-TRANSPORT-PROTOCOL-CONFIGURATION>
                                <it:NETWORK-ENDPOINT-REF ID-REF="NEP_CONSUMER6"/>
                                <it:CONSUMED-SERVICE-INSTANCES>
                                    <it:CONSUMED-SERVICE-INSTANCE ID="CSI_ECHO6">
                                        <it:PROVIDED-SERVICE-INSTANCE-REF ID-REF="PSI_ECHO6"/>
                                        <it:CONSUMED-EVENT-GROUPS>
                                            <it:CONSUMED-EVENT-GROUP ID="CEG6_EG1">
                                                <service:EVENT-GROUP-REF ID-REF="EG6_1"/>
                                                <it:APPLICATION-ENDPOINT-REF ID-REF="AEP_CONSUMER6"/>
                                            </it:CONSUMED-EVENT-GROUP>
                                        </it:CONSUMED-EVENT-GROUPS>
                                    </it:CONSUMED-SERVICE-INSTANCE>
                                </it:CONSUMED-SERVICE-INSTANCES>
                            </it:APPLICATION-ENDPOINT>
                        </it:APPLICATION-ENDPOINTS>

                    </fx:CONNECTOR>
                </fx:CONNECTORS>
            </fx:ECU>

        </fx:ECUS>

        <fx:SERVICE-INTERFACES>
            <fx:SERVICE-INTERFACE ID="SVC_ECHO6" xsi:type="service:SERVICE-INTERFACE-TYPE">
                <ho:SHORT-NAME>SVC_ECHO6</ho:SHORT-NAME>
                <fx:SERVICE-IDENTIFIER>4661</fx:SERVICE-IDENTIFIER>
                <service:API-VERSION>
                    <service:MAJOR>1</service:MAJOR>
                    <service:MINOR>0</service:MINOR>
                </service:API-VERSION>

                <service:METHODS>
                    <service:METHOD ID="METHOD6_GETVALUE">
                        <ho:SHORT-NAME>GetValue</ho:SHORT-NAME>
                        <service:METHOD-IDENTIFIER>1</service:METHOD-IDENTIFIER>
                        <service:CALL-SEMANTIC>REQUEST_RESPONSE</service:CALL-SEMANTIC>
                        <service:INPUT-PARAMETERS>
                            <service:INPUT-PARAMETER ID="PARAM6_IN1">
                                <ho:SHORT-NAME>requestValue</ho:SHORT-NAME>
                                <fx:DATATYPE-REF ID-REF="DT6_UINT8"/>
                                <service:POSITION>0</service:POSITION>
                                <service:MANDATORY>true</service:MANDATORY>
                            </service:INPUT-PARAMETER>
                        </service:INPUT-PARAMETERS>
                        <service:RETURN-PARAMETERS>
                            <service:RETURN-PARAMETER ID="PARAM6_OUT1">
                                <ho:SHORT-NAME>responseValue</ho:SHORT-NAME>
                                <fx:DATATYPE-REF ID-REF="DT6_UINT8"/>
                                <service:POSITION>0</service:POSITION>
                                <service:MANDATORY>true</service:MANDATORY>
                            </service:RETURN-PARAMETER>
                        </service:RETURN-PARAMETERS>
                        <service:RELIABLE>false</service:RELIABLE>
                    </service:METHOD>
                </service:METHODS>

                <service:EVENTS>
                    <service:EVENT ID="EVENT6_STATUS">
                        <ho:SHORT-NAME>StatusEvent</ho:SHORT-NAME>
                        <service:METHOD-IDENTIFIER>32769</service:METHOD-IDENTIFIER>
                        <service:INPUT-PARAMETERS>
                            <service:INPUT-PARAMETER ID="PARAM6_EVT1">
                                <ho:SHORT-NAME>statusValue</ho:SHORT-NAME>
                                <fx:DATATYPE-REF ID-REF="DT6_UINT8"/>
                                <service:POSITION>0</service:POSITION>
                                <service:MANDATORY>true</service:MANDATORY>
                            </service:INPUT-PARAMETER>
                        </service:INPUT-PARAMETERS>
                        <service:RELIABLE>false</service:RELIABLE>
                    </service:EVENT>
                </service:EVENTS>

                <service:EVENT-GROUPS>
                    <service:EVENT-GROUP ID="EG6_1">
                        <ho:SHORT-NAME>EG1</ho:SHORT-NAME>
                        <fx:SERVICE-IDENTIFIER>1</fx:SERVICE-IDENTIFIER>
                        <service:EVENT-REFS>
                            <service:EVENT-REF ID-REF="EVENT6_STATUS"/>
                        </service:EVENT-REFS>
                    </service:EVENT-GROUP>
                </service:EVENT-GROUPS>

            </fx:SERVICE-INTERFACE>
        </fx:SERVICE-INTERFACES>

        <fx:DATATYPES>
            <fx:DATATYPE xsi:type="fx:COMMON-DATATYPE-TYPE" ID="DT6_UINT8">
                <ho:SHORT-NAME>UINT8</ho:SHORT-NAME>
                <fx:CODING-REF ID-REF="COD6_UINT8"/>
            </fx:DATATYPE>
        </fx:DATATYPES>

    </fx:ELEMENTS>

    <fx:PROCESSING-INFORMATION>
        <fx:CODINGS>
            <fx:CODING ID="COD6_UINT8">
                <ho:SHORT-NAME>UINT8Coding</ho:SHORT-NAME>
                <ho:CODED-TYPE CATEGORY="STANDARD-LENGTH-TYPE" ho:BASE-DATA-TYPE="A_UINT8">
                    <ho:BIT-LENGTH>8</ho:BIT-LENGTH>
                </ho:CODED-TYPE>
            </fx:CODING>
        </fx:CODINGS>
    </fx:PROCESSING-INFORMATION>

</fx:FIBEX>
